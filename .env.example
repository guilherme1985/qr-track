# =====================================================================
# ARKHAM FILES — Environment configuration
# Copie este arquivo para .env e ajuste para o ambiente atual.
# =====================================================================

# --- Application -----------------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_URL=https://qrtrack.arkhamcloud.net
APP_TIMEZONE=America/Sao_Paulo

# --- Storage paths (caminhos absolutos em produção) ------------------
DB_PATH=/var/www/qrtrack/data/qrtrack.sqlite
UPLOAD_PATH=/var/www/qrtrack/uploads
STORAGE_PATH=/var/www/qrtrack/storage

# --- Sessions --------------------------------------------------------
SESSION_LIFETIME=86400
SESSION_NAME=arkham_session

# --- Security --------------------------------------------------------
# Chave usada para cifrar TOTP secrets em repouso.
# Gere com: php -r "echo bin2hex(random_bytes(32));"
TOTP_ENCRYPTION_KEY=

# --- Cloudflare / Proxy ---------------------------------------------
USE_CLOUDFLARE_TUNNEL=true
TRUSTED_PROXIES=192.168.15.10,127.0.0.1

# --- Limites e retenção ---------------------------------------------
MAX_UPLOAD_SIZE=1048576
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=900
AUDIT_LOG_RETENTION_DAYS=30
LOGIN_ATTEMPTS_RETENTION_HOURS=24
